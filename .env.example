# =============================================================
# AI Orchestration Layer - Albeni 1905
# Environment Configuration
# =============================================================

# --- Database (PostgreSQL) ---
DB_USER=albeni_admin
DB_PASSWORD=your_secure_password_here
DB_HOST=db
DB_PORT=5432
DB_NAME=albeni_ai_db
DATABASE_URL=postgresql://albeni_admin:your_secure_password_here@db:5432/albeni_ai_db

# --- Redis (Caching Layer) ---
REDIS_URL=redis://redis:6379

# --- AI Provider: "gemini" (default) or "openai" ---
AI_PROVIDER=gemini

# --- Google Gemini (DEFAULT - Content Generation & Analysis) ---
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash

# --- OpenAI (ALTERNATIVE - uncomment if using OpenAI instead) ---
# AI_PROVIDER=openai
# OPENAI_API_KEY=sk-your-openai-key-here
# OPENAI_MODEL=gpt-4o

# --- Klaviyo (CRM Integration) ---
KLAVIYO_API_KEY=pk_your_klaviyo_private_key
KLAVIYO_PUBLIC_KEY=your_klaviyo_public_key
KLAVIYO_REVISION=2024-02-15

# --- Google Analytics 4 (Server-Side Tracking) ---
GA4_MEASUREMENT_ID=G-XXXXXXXXXX
GA4_API_SECRET=your_ga4_api_secret

# --- Shopify (Commerce Integration) ---
SHOPIFY_STORE_URL=https://albeni1905.myshopify.com
SHOPIFY_ACCESS_TOKEN=your_shopify_access_token

# --- ML Worker URL (internal Docker network) ---
ML_WORKER_URL=http://ml-worker:8000

# --- AI Router Configuration ---
PORT=3000
NODE_ENV=production

# --- Domain Configuration ---
DOMAIN_TOFU=https://worldofmerino.com
DOMAIN_MOFU=https://merinouniversity.com
DOMAIN_BOFU_TECH=https://perfectmerinoshirt.com
DOMAIN_BOFU_HERITAGE=https://albeni1905.com

# --- IDS Thresholds ---
IDS_TOFU_MAX=30
IDS_MOFU_MAX=65
IDS_BOFU_MIN=65

# --- CPA Alert Thresholds (EUR) ---
CPA_GREEN_MAX=9
CPA_YELLOW_MAX=15

# --- Cannibalization Alert Threshold (%) ---
CANNIBALIZATION_WARNING=6
CANNIBALIZATION_CRITICAL=12

# --- Security ---
JWT_SECRET=your_jwt_secret_for_api_auth
API_KEY=your_internal_api_key
