# Notion integration token — reuse "Albeni AI Stack" integration
# that already has access to the Content Pipeline database.
NOTION_TOKEN=ntn_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Content Pipeline database ID
NOTION_DB_ID=98a46d373b7d4455ad860da224b00b01

# Shared secret between webhook and dashboard (openssl rand -hex 32)
WEBHOOK_SECRET=change_me_to_a_long_random_string

# CORS allow-list. "*" for dev (file:// origin), specific domain for prod.
ALLOWED_ORIGINS=*

# Railway sets $PORT automatically
# PORT=3001
