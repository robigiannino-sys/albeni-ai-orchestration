# Same Notion token used by approval-webhook
NOTION_TOKEN=ntn_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DB_ID=98a46d373b7d4455ad860da224b00b01

# Railway URL of approval-webhook service (after deploy)
# Example: https://approval-webhook-production.up.railway.app
WEBHOOK_URL=https://your-approval-webhook.up.railway.app

# Must match approval-webhook's WEBHOOK_SECRET
WEBHOOK_SECRET=change_me_to_a_long_random_string

# Output path for generated dashboard HTML (absolute or relative to this dir)
OUTPUT_PATH=../../dashboard/approval-dashboard.html
